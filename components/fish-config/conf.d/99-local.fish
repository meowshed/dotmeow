# ~/.config/fish/conf.d/99-local.fish
# Machine-specific overrides and secrets.
#
# This file is intentionally NOT tracked by dotmeow. It is created by the
# fish-config component as a placeholder, but modifications here are local
# and will persist across `meowctl apply` runs.
#
# Use this for:
#   - Work-specific PATH additions
#   - API keys or tokens (never commit these)
#   - Temporary aliases during experimentation
#   - Per-host workarounds
#
# Example:
#   set -gx OPENAI_API_KEY sk-...
#   fish_add_path /opt/work/bin
#
# To reload after editing: source ~/.config/fish/conf.d/99-local.fish
