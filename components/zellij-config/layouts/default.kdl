// @file: components/zellij/config/zellij/layouts/default.kdl
// @brief: Default zellij layout with zjstatus status bar at the top.
// @author: Andrew Vasilyev
// @license: MIT
//
// Prerequisites:
//   zjstatus is loaded directly from GitHub releases — no manual download needed.
//   Zellij caches the wasm after first load.
//
//   The zjstatus-widgets Hammerspoon plugin must be installed and Hammerspoon
//   must be running.  It pushes all widget values (keyboard, VPN, battery,
//   CPU, memory, focus mode, date, time) as pipe events — no polling, no daemons.

layout {
    default_tab_template {
        // Status bar at the TOP (declared before children)
        pane size=2 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {

                format_center ""
                format_right  "{pipe_vpn}{pipe_focus}{pipe_cpu}{pipe_memory}{pipe_keyboard}{pipe_battery}{pipe_date}{pipe_time}"

                border_enabled  "false"
                hide_frame_for_single_pane "false"
                mode_default_to_mode "normal"

                // All widgets pushed by the zjstatus-widgets Hammerspoon plugin.
                // Colors are embedded in the piped value by Lua (Catppuccin Mocha, static).
                pipe_vpn_rendermode      "dynamic"
                pipe_focus_rendermode    "dynamic"
                pipe_keyboard_rendermode "dynamic"
                pipe_cpu_rendermode      "dynamic"
                pipe_memory_rendermode   "dynamic"
                pipe_battery_rendermode  "dynamic"
                pipe_date_rendermode     "dynamic"
                pipe_time_rendermode     "dynamic"

                // ZJSTATUS_COLORS_BEGIN (managed by apply-theme-zellij — do not edit manually)
                 // bg=#1e1e2e fg=#cdd6f4 sel=#313244 dim=#7f849c subtle=#bac2de
                 // teal=#94e2d5 blue=#89b4fa mauve=#cba6f7 green=#a6e3a1
                 // yellow=#f9e2af orange=#fab387 red=#f38ba8
                 format_left              "{mode}#[fg=#1e1e2e,bg=#94e2d5,bold] {session} #[fg=#94e2d5,bg=#1e1e2e]{tabs}"
                 format_space             "#[bg=#1e1e2e]"
                 tab_normal               "#[fg=#7f849c,bg=#1e1e2e] {index} {name} "
                 tab_active               "#[fg=#cdd6f4,bg=#313244,bold] {index} {name} "
                 tab_separator            "#[fg=#313244,bg=#1e1e2e]"
                 mode_normal              "#[fg=#7f849c,bg=#1e1e2e] NORMAL "
                 mode_pane                "#[fg=#1e1e2e,bg=#89b4fa,bold] PANE "
                 mode_tab                 "#[fg=#1e1e2e,bg=#cba6f7,bold] TAB "
                 mode_scroll              "#[fg=#1e1e2e,bg=#a6e3a1,bold] SCROLL "
                 mode_search              "#[fg=#1e1e2e,bg=#f9e2af,bold] SEARCH "
                 mode_enter_search        "#[fg=#1e1e2e,bg=#f9e2af,bold] SEARCH "
                 mode_session             "#[fg=#1e1e2e,bg=#94e2d5,bold] SESSION "
                 mode_move                "#[fg=#1e1e2e,bg=#fab387,bold] MOVE "
                 mode_locked              "#[fg=#1e1e2e,bg=#f38ba8,bold] LOCKED "
                 mode_resize              "#[fg=#1e1e2e,bg=#f9e2af,bold] RESIZE "
                 mode_rename_pane         "#[fg=#1e1e2e,bg=#f9e2af,bold] RENAME "
                 mode_rename_tab          "#[fg=#1e1e2e,bg=#f9e2af,bold] RENAME "
                 pipe_vpn_format          "{output}  "
                 pipe_focus_format        "{output}  "
                 pipe_keyboard_format     "{output}  "
                 pipe_cpu_format          "{output}  "
                 pipe_memory_format       "{output}  "
                 pipe_battery_format      "{output}  "
                 pipe_date_format         "{output}  "
                 pipe_time_format         "{output}"
                 // ZJSTATUS_COLORS_END
            }
        }

        children
    }
}
