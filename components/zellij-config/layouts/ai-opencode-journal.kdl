layout {
    pane split_direction="vertical" {
        pane size="60%" split_direction="horizontal" {
            pane command="nvim" size="70%" focus=true
            pane command="fish" size="30%" {
                name "fish"
            }
        }
        pane command="fish" size="40%" {
            name "opencode-journal"
            args "-lc" "set -l root (git rev-parse --show-toplevel 2>/dev/null); test -n \"$root\"; or set root \"$PWD\"; zellij_opencode_journal \"$root\""
        }
    }
}
