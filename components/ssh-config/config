# ssh-config — reference defaults
#
# Put host-specific entries in ~/.ssh/config.d/ and include them:
#   Include ~/.ssh/config.d/*
#
# This file provides global defaults only.

Host *
    # Prefer ed25519 keys; fall back to rsa-sha2 variants.
    IdentityFile ~/.ssh/id_ed25519

    # Store passphrases in macOS Keychain so protected keys don't prompt repeatedly.
    # IgnoreUnknown keeps non-Apple ssh builds (e.g. Homebrew's OpenSSL OpenSSH, which
    # lacks UseKeychain) from aborting on this option instead of skipping it.
    IgnoreUnknown UseKeychain
    AddKeysToAgent yes
    UseKeychain yes

    # Connection multiplexing — reuse connections to the same host.
    # 60 s persistence avoids stale sockets from killed terminals.
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 60

    # Keep connections alive through NAT/firewall timeouts
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Prefer modern algorithms
    HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-rsa-cert-v01@openssh.com,ssh-ed25519,rsa-sha2-512,rsa-sha2-256

    # Disable password auth by default (use keys)
    PasswordAuthentication no
    PreferredAuthentications publickey
